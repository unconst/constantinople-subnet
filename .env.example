# Wallet config
WALLET_NAME=validator
HOTKEY_NAME=default
NETUID=97
NETWORK=finney
# IMPORTANT: Use an absolute path (tilde ~ does not expand in Docker)
WALLET_PATH=/root/.bittensor/wallets

# R2 credentials for reading epoch data — ask Arbos in Discord for these values
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
